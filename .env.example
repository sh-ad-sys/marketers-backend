# Storage backend
# Set to "mongo" if you do not want to use MySQL.
PLOTCONNECT_STORAGE=mongo

# MongoDB Configuration
MONGODB_URI=mongodb+srv://username:password@cluster0.example.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=plotconnect
MONGODB_TLS=true
MONGODB_TLS_CA_FILE=/etc/ssl/certs/ca-certificates.crt
APP_TIMEZONE=Africa/Nairobi
# If Atlas is used from Render, allow the Render service IP/CIDR in Atlas Network Access.

# MySQL Configuration
# Only needed when PLOTCONNECT_STORAGE=mysql
DB_HOST=your_mysql_host
DB_PORT=3306
DB_NAME=your_mysql_database
DB_USER=your_mysql_user
DB_PASS=your_mysql_password

# Password reset email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM_EMAIL=no-reply@your-domain.com
SMTP_FROM_NAME=PlotConnect
SMTP_SECURE=tls
# Public reset routes. If unset, the API falls back to the request Origin.
RESET_USER_URL=https://plotconnect-marketer.vercel.app/reset-password
RESET_ADMIN_URL=https://your-admin-frontend.example/reset-password

# Main Admin Credentials
PRIMARY_ADMIN_USERNAME=techswift-admin
PRIMARY_ADMIN_EMAIL=techswifttrix361@gmail.com
# Password: B40-6y3
PRIMARY_ADMIN_PASSWORD=$2y$10$rHG5kf0ec8HNy3VF4UPC4u0L1ZFijuwOJ5.PzRHWCqN6JNmSl2t2u

# Ledger Credentials
LEDGER_ADMIN_USERNAME=ledger
LEDGER_ADMIN_EMAIL=ledger@plotconnect.com
# Password: R36@ledger001
LEDGER_ADMIN_PASSWORD=$2y$10$Tq9uK4B2sus4WwzuUzUyUu/SwV7oyVWX73cOTJGGq6LUbzsiz/H9W

# Legacy fallback: leave ADMIN_* unset on new deployments so PRIMARY_* and LEDGER_* stay separate.
# ADMIN_USERNAME=
# ADMIN_EMAIL=
# ADMIN_PASSWORD=

# Daraja / MPesa Configuration
# Use your public backend URL so Daraja can reach the callback endpoint.
APP_URL=https://your-backend-domain.com
# Use "production" with live credentials if you expect a real phone to receive the STK prompt.
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your_lipa_na_mpesa_passkey
# Optional when APP_URL is set. Must be public HTTPS, not localhost.
MPESA_CALLBACK_URL=https://your-backend-domain.com/api/marketer/mpesa-callback.php
MPESA_TRANSACTION_TYPE=CustomerPayBillOnline

# Note: Copy this to .env and fill in your actual values
# Never commit .env to version control!
